# Base de données PostgreSQL (Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/db?schema=public"

# Utilisateur (affiché sur la page pricing)
USER_EMAIL=demo@claude.ai
USER_NAME=Demo User

# Stripe — Mode Test
# Clé secrète : Dashboard Stripe > Developers > API keys > Secret key
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret : copié depuis la sortie de `stripe listen`
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — voir README.md pour les créer
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_MAX_MONTHLY_PRICE_ID=price_...
STRIPE_MAX_YEARLY_PRICE_ID=price_...

# URL de l'app
NEXT_PUBLIC_APP_URL=http://localhost:3000
